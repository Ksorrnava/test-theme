{{ attach_library('elfbv/visually-impaired') }}

<div id="visually_impaired_icons" class="visually-impaired-icons d-none">
  <div class="access row mx-auto">
    <div class="text-center col-sm-6 col-lg-3">
      <dl class="a-fontsize d-inline-block">
      <dt>{% trans %}Font size{% endtrans %}:</dt>
      <dd><a href="#" rel="fontsize-small" class="a-fontsize-small"></a></dd>
      <dd><a rel="fontsize-normal" href="#" class="a-fontsize-normal"></a></dd>
      <dd><a href="#" rel="fontsize-big" class="a-fontsize-big"></a></dd>
      </dl>
    </div>

    <div class="text-center col-sm-6 col-lg-3">
      <dl class="a-colors d-inline-block">
        <dt>{% trans %}Site colors{% endtrans %}:</dt>
        <dd><a href="#" rel="color1" class="a-color1"></a></dd>
        <dd><a href="#" rel="color2" class="a-color2"></a></dd>
        <dd><a href="#" rel="color3" class="a-color3"></a></dd>
      </dl>
    </div>

    <div class="text-center col-sm-6 col-lg-3">
      <dl class="a-images d-inline-block">
        <dt>{% trans %}Images{% endtrans %}:</dt>
        <dd><a rel="imgcolor" href="#" class="a-imgcolor"></a></dd>
        <dd><a rel="imggray" href="#" class="a-imggray"></a></dd>
        <dd><a rel="imgnone" href="#" class="a-imgnone"></a></dd>
      </dl>
    </div>

    <div class="text-center col-sm-6 col-lg-3">
      <dl class="a-kerning d-inline-block">
        <dt>{% trans %}Kerning{% endtrans %}:</dt>
        <dd><a rel="kernstd" href="#" class="a-kernstd"></a></dd>
        <dd><a rel="kernmid" href="#" class="a-kernmid"></a></dd>
        <dd><a rel="kernbig" href="#" class="a-kernbig"></a></dd>
      </dl>
    </div>

  </div>
</div>
