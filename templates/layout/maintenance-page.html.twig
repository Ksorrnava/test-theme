{#
/**
 * @file
 * Theme override to display a single Drupal page while offline.
 *
 * All available variables are mirrored in page.html.twig.
 * Some may be blank but they are provided for consistency.
 *
 * @see template_preprocess_maintenance_page()
 */
#}
<main role="main" class="error">
  <div class="error__wrapper">
    <div class="error__background-image">
      <img src="{{ file_url('/themes/custom/elfbv/assets/media/errors/bg-error-main.svg') }}" alt="">
    </div>
    <div class="error__message">
      <p class="error__title">{{ 'Technical work on the site'|t }}</p>
      <h1 class="error__text">
        {% if title|render|striptags|trim %}
          {{ title }}
        {% endif %}
        {{ page.highlighted }}
        {{ page.content }} </h1>
    </div>
  </div>
</main>
