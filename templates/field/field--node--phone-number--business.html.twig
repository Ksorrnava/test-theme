{#
/**
 * @file
 * Theme override for a field.
 *
 * @see template_preprocess_field()
 */
#}
{% for item in items %}
  <div class="social-link--wrapper">
    <a href="{{ item.content["#url"].toString }}" class="phone">
      <span class="label">{{ 'Phone:' }}</span><span class="username">{{ item.content["#title"] }}</span>
    </a>
  </div>
{% endfor %}
